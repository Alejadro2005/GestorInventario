#:import dp kivy.metrics.dp

<ActualizarStockScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        canvas.before:
            Color:
                rgba: 0.95, 0.95, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: '[b]ACTUALIZAR STOCK[/b]'
            markup: True
            font_size: dp(24)
            color: 0.1, 0.4, 0.8, 1
            size_hint_y: None
            height: dp(40)

        GridLayout:
            cols: 2
            spacing: dp(10)
            row_default_height: dp(40)
            size_hint_y: None
            height: self.minimum_height

            Label:
                text: 'ID del Producto:'
                color: 0.2, 0.2, 0.2, 1
            TextInput:
                id: id_producto
                input_filter: 'int'
                hint_text: 'Ej: 101'
                background_color: 1, 1, 1, 1

            Label:
                text: 'Nueva Cantidad:'
                color: 0.2, 0.2, 0.2, 1
            TextInput:
                id: nueva_cantidad
                input_filter: 'int'
                hint_text: 'Ej: 25'
                background_color: 1, 1, 1, 1

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(10)

            Button:
                text: 'ACTUALIZAR'
                background_color: 0.1, 0.8, 0.4, 1
                on_press: root.actualizar_stock()

            Button:
                text: 'CANCELAR'
                background_color: 0.8, 0.1, 0.1, 1
                on_press: root.manager.current = 'productos_menu'
