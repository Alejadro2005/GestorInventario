#:import dp kivy.metrics.dp

<EliminarProductoScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)

        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: '[b]ELIMINAR PRODUCTO[/b]'
            markup: True
            font_size: dp(24)
            color: 0.8, 0.1, 0.1, 1
            size_hint_y: None
            height: dp(40)

        Label:
            text: "Ingrese el ID del producto a eliminar:"
            font_size: dp(16)
            color: 0.2, 0.2, 0.2, 1
            size_hint_y: None
            height: dp(30)

        TextInput:
            id: id_eliminar
            hint_text: "Ej: 1001"
            input_filter: 'int'
            multiline: False
            size_hint_y: None
            height: dp(40)
            background_color: 1, 1, 1, 1

        BoxLayout:
            spacing: dp(10)
            size_hint_y: None
            height: dp(50)

            Button:
                text: "Eliminar"
                background_color: 0.8, 0.1, 0.1, 1
                on_press: root.eliminar_producto()

            Button:
                text: "Volver"
                background_color: 0.6, 0.6, 0.6, 1
                on_press: root.manager.current = 'productos_menu'
